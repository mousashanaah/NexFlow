{% comment %} Renders a Golf4Less product card. Param: product {% endcomment %}
{%- assign on_sale = false -%}
{%- if product.compare_at_price > product.price -%}{%- assign on_sale = true -%}{%- endif -%}
<article class="card">
  <a href="{{ product.url }}" class="card-media">
    {%- if on_sale -%}
      {%- assign save_pct = product.compare_at_price | minus: product.price | times: 100.0 | divided_by: product.compare_at_price | round -%}
      <span class="tag save">Save {{ save_pct }}%</span>
    {%- elsif product.tags contains 'new' -%}
      <span class="tag new">New In</span>
    {%- endif -%}
    <button class="wish" type="button" aria-label="Wishlist"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 21s-7-4.5-9.5-8.5C.5 9 2 5.5 5.2 5.5c1.9 0 3.1 1 3.8 2 .7-1 1.9-2 3.8-2 3.2 0 4.7 3.5 2.7 7C19 16.5 12 21 12 21z"/></svg></button>
    {%- if product.featured_image -%}
      <img src="{{ product.featured_image | image_url: width: 400 }}" alt="{{ product.featured_image.alt | escape | default: product.title }}" loading="lazy" width="400">
    {%- else -%}
      <img src="{{ 'golfball.svg' | asset_url }}" alt="{{ product.title }}" loading="lazy">
    {%- endif -%}
  </a>
  <div class="card-body">
    <span class="card-brand">{{ product.vendor }}</span>
    <a href="{{ product.url }}"><h3 class="card-name">{{ product.title }}</h3></a>
    {%- if product.metafields.reviews.rating -%}
      <div class="stars">{{ product.metafields.reviews.rating.value | times: 1 | round }} ★ <span>({{ product.metafields.reviews.rating_count }})</span></div>
    {%- endif -%}
    <div class="price-row">
      <span class="now">{{ product.price | money }}</span>
      {%- if on_sale -%}<span class="was">{{ product.compare_at_price | money }}</span>{%- endif -%}
    </div>
    <product-form>
      {%- form 'product', product, class: 'card-form' -%}
        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
        <button type="submit" class="btn btn-dark add" {% unless product.available %}disabled{% endunless %}>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 7h14l-1.5 12.5a1.5 1.5 0 0 1-1.5 1.5H8a1.5 1.5 0 0 1-1.5-1.5z"/><path d="M9 7V5a3 3 0 0 1 6 0v2"/></svg>
          {% if product.available %}Add to Bag{% else %}Sold Out{% endif %}
        </button>
      {%- endform -%}
    </product-form>
  </div>
</article>
