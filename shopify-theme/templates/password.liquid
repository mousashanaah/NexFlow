<div class="wrap" style="text-align:center;padding:100px 0">
  <img src="{{ 'mascot.svg' | asset_url }}" alt="" style="width:140px;margin:0 auto 18px">
  <h1 class="display" style="font-size:3rem">{{ shop.name }}</h1>
  <p class="lede" style="margin:10px auto 24px">{{ shop.password_message | default: 'Spend Less. Play More. Launching soon.' }}</p>
  {% form 'storefront_password' %}
    <input type="password" name="password" placeholder="Enter store password" style="padding:14px 18px;border-radius:999px;border:1.5px solid var(--line);font-family:inherit">
    <button type="submit" class="btn btn-green">Enter</button>
  {% endform %}
</div>
