<div class="wrap" style="padding:50px 0 80px">
  <h1 class="display" style="font-size:2.2rem;margin-bottom:16px">Order {{ order.name }}</h1>
  <p style="color:var(--muted);margin-bottom:20px">Placed {{ order.created_at | date: '%B %d, %Y' }}</p>
  {% for line in order.line_items %}
    <div class="s-item"><div class="s-meta" style="flex:1"><b>{{ line.title }}</b><small>Qty {{ line.quantity }}</small></div><div class="s-price">{{ line.final_line_price | money }}</div></div>
  {% endfor %}
  <div class="s-total"><span>Total</span><span>{{ order.total_price | money }}</span></div>
</div>
