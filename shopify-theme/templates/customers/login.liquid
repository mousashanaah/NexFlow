<div class="wrap" style="max-width:460px;padding:50px 0 80px">
  <h1 class="display" style="font-size:2.4rem;margin-bottom:20px">Sign In</h1>
  {% form 'customer_login' %}
    {{ form.errors | default_errors }}
    <div class="field"><input type="email" name="customer[email]" placeholder="Email" required></div>
    <div class="field"><input type="password" name="customer[password]" placeholder="Password"></div>
    <button type="submit" class="btn btn-dark" style="width:100%;justify-content:center">Sign In</button>
  {% endform %}
  <p style="margin-top:16px;font-size:0.9rem">New here? <a href="{{ routes.account_register_url }}" style="color:var(--green-deep);font-weight:600">Create an account</a></p>
</div>
