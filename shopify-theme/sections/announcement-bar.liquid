<div class="announce" aria-hidden="true">
  <div class="track">
    {% for i in (1..2) %}
      {% for block in section.blocks %}
        <span>{{ block.settings.text }}</span>
      {% endfor %}
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "Announcement bar",
  "blocks": [
    { "type": "message", "name": "Message", "settings": [
      { "type": "text", "id": "text", "label": "Text", "default": "🚚 FREE next-day UAE delivery over AED 250" }
    ]}
  ],
  "presets": [{ "name": "Announcement bar" }],
  "default": {
    "blocks": [
      { "type": "message", "settings": { "text": "🚚 FREE next-day UAE delivery over AED 250" } },
      { "type": "message", "settings": { "text": "⛳ FREE custom ball printing on 3+ dozen" } },
      { "type": "message", "settings": { "text": "🌍 We ship across the GCC & Africa" } },
      { "type": "message", "settings": { "text": "💬 Shop live on WhatsApp" } }
    ]
  }
}
{% endschema %}
