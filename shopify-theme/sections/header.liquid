<header class="header" id="header">
  <div class="wrap nav">
    <a class="brand" href="{{ routes.root_url }}" aria-label="{{ shop.name }} home">
      {% if settings.logo %}
        <img class="mark" src="{{ settings.logo | image_url: width: 120 }}" alt="{{ shop.name }}" width="44">
      {% else %}
        <img class="mark" src="{{ 'logo-mark.svg' | asset_url }}" alt="">
        <span class="word">GOLF<b>4</b>LESS</span>
      {% endif %}
    </a>

    <nav class="nav-links" aria-label="Primary">
      {% for link in linklists[settings.menu].links %}
        <a href="{{ link.url }}"{% if forloop.first %} class="hot"{% endif %}>{{ link.title }}</a>
      {% endfor %}
    </nav>

    <div class="nav-actions">
      <a class="icon-btn" href="{{ routes.search_url }}" aria-label="Search">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
      </a>
      <a class="icon-btn" href="{{ routes.account_url }}" aria-label="Account">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="4"/><path d="M4 21c0-4 4-7 8-7s8 3 8 7"/></svg>
      </a>
      <a class="icon-btn" href="{{ routes.cart_url }}" aria-label="Cart">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 7h14l-1.5 12.5a1.5 1.5 0 0 1-1.5 1.5H8a1.5 1.5 0 0 1-1.5-1.5z"/><path d="M9 7V5a3 3 0 0 1 6 0v2"/></svg>
        <span class="cart-count" id="cartCount">{{ cart.item_count }}</span>
      </a>
      <button class="icon-btn burger" id="burger" aria-label="Menu">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
      </button>
    </div>
  </div>
</header>

{% if section.settings.show_subnav %}
  <div class="subnav">
    <div class="wrap">
      {% for link in linklists[section.settings.subnav_menu].links %}
        <a href="{{ link.url }}"{% if link.title contains 'Sale' %} class="sale"{% endif %}>{{ link.title }}</a>
      {% endfor %}
    </div>
  </div>
{% endif %}

{% schema %}
{
  "name": "Header",
  "settings": [
    { "type": "checkbox", "id": "show_subnav", "label": "Show category sub-nav", "default": true },
    { "type": "link_list", "id": "subnav_menu", "label": "Sub-nav menu", "default": "main-menu" }
  ]
}
{% endschema %}
